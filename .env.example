# Web Push configuration.
#
# Generate a VAPID keypair with:  npx web-push generate-vapid-keys --json
# The PUBLIC key is the same value in two places: the client build var
# (VITE_VAPID_PUBLIC_KEY) and the server var (VAPID_PUBLIC).

# --- Client (build-time, safe to expose) ---
VITE_VAPID_PUBLIC_KEY=

# --- Server only (set in Vercel env, never commit real values) ---
# VAPID_PUBLIC=            # same value as VITE_VAPID_PUBLIC_KEY
# VAPID_PRIVATE=           # keep secret
# VAPID_SUBJECT=mailto:cat@ninthlifeinsights.com
# CRON_SECRET=             # shared secret required by /api/send-push
# FIREBASE_SERVICE_ACCOUNT= # service-account JSON as a single-line string

# Existing:
# ANTHROPIC_API_KEY=
